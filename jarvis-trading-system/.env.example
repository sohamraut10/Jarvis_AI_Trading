# ── Dhan API credentials ──────────────────────────────────────────────────────
DHAN_CLIENT_ID=your_client_id_here
DHAN_ACCESS_TOKEN=your_access_token_here

# ── Trading mode ──────────────────────────────────────────────────────────────
PAPER_MODE=true                   # true = paper trading, false = live

# ── Capital & risk controls ───────────────────────────────────────────────────
INITIAL_CAPITAL=10000             # INR, paper capital
KILL_SWITCH_PCT=0.03              # 3 % daily drawdown triggers hard stop
KELLY_FRACTION=0.5                # Half-Kelly sizing

# ── Regime / strategy config ──────────────────────────────────────────────────
HMM_STATES=4                      # TRENDING_UP, TRENDING_DOWN, SIDEWAYS, HIGH_VOL
REGIME_LOOKBACK_BARS=200          # bars fed to HMM for initial fit
SHARPE_RANK_WINDOW_DAYS=20        # rolling window for daily capital rotation

# ── WebSocket server ──────────────────────────────────────────────────────────
WS_HOST=0.0.0.0
WS_PORT=8765

# ── Layer 5 AI Brain — LLM API keys ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Set to true during the 7-day paper trading phase to skip cost recording
# for Gemini calls (free tier covers up to 1500 req/day on Flash models).
GEMINI_FREE_TIER=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
INTENT_LOG_PATH=logs/intent.jsonl
PNL_DB_PATH=data/pnl.db
